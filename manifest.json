{
  "manifest_version": 3,
  "name": "Tab Organizer",
  "version": "1.0",
  "description": "Organize, search, group, and manage your Chrome tabs.",
  "permissions": ["tabs", "tabGroups"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Organizer"
  },
  "background": {
    "service_worker": "background.js"
  }
}
